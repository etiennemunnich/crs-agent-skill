# CRS + Albedo test environment
# Copy to .env and adjust before deployment.
# Compose works without .env — defaults in docker-compose*.yaml apply.

CRS_DOCKER_PORT=8080

# ── CRS Tuning ──────────────────────────────────────────────────────
# IMPORTANT: Review and confirm these values before testing or
# deploying. Defaults are safe starting points (PL1, standard
# thresholds). Adjust to match your target environment.
#
#   PARANOIA            — Detection paranoia level (1–4). Higher = more
#                         rules active = more potential false positives.
#   BLOCKING_PARANOIA   — Paranoia level used for blocking decisions.
#                         Keep equal to PARANOIA unless split-PL tuning.
#   ANOMALY_INBOUND     — Inbound anomaly score threshold for blocking.
#                         CRS default: 5 (PL1). Lower = stricter.
#   ANOMALY_OUTBOUND    — Outbound anomaly score threshold for blocking.
#                         CRS default: 4. Rarely needs changing.
#
# See: references/paranoia-levels.md, references/anomaly-scoring.md
# ────────────────────────────────────────────────────────────────────
# PARANOIA=1
# BLOCKING_PARANOIA=1
# ANOMALY_INBOUND=5
# ANOMALY_OUTBOUND=4

# Override compose file location
# COMPOSE_FILE=/path/to/docker-compose.yaml

# Force container runtime (auto-detects Docker, then Finch)
# CONTAINER_CLI="docker compose"
# CONTAINER_CLI="finch compose"

# Coraza testing (instead of ModSecurity)
# COMPOSE_FILE=assets/docker/docker-compose.coraza.yaml
